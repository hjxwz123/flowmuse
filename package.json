{
  "name": "aigallery",
  "version": "1.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/src/main.js",
    "start:frontend": "cd frontend/.next/standalone/frontend && BACKEND_URL=${BACKEND_URL:-http://127.0.0.1:${PORT:-3000}} PORT=${FRONTEND_PORT:-3001} node server.js",
    "start:all": "concurrently \"npm run start\" \"npm run start:frontend\"",
    "prestart:dev": "npm run prisma:generate",
    "start:dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "dev:all": "concurrently \"npm run start:dev\" \"cd frontend && BACKEND_URL=${BACKEND_URL:-http://127.0.0.1:${PORT:-3000}} FRONTEND_PORT=${FRONTEND_PORT:-5173} npm run dev\"",
    "prebuild": "npm run prisma:generate",
    "build": "rimraf dist && tsc -p tsconfig.build.json",
    "build:frontend": "cd frontend && npm run build && cd .. && cp -r frontend/.next/static frontend/.next/standalone/frontend/.next/ && cp -r frontend/public frontend/.next/standalone/frontend/",
    "build:all": "npm run build && npm run build:frontend",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:backfill:storyboard": "node prisma/backfill-video-task-storyboard-columns.js",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@nestjs/axios": "^3.1.3",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.20",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.20",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.20",
    "@nestjs/schedule": "^3.0.4",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.66.4",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "cron": "^3.5.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.9.1",
    "mime-types": "^2.1.35",
    "multer": "^2.0.2",
    "nanoid": "^5.1.6",
    "nodemailer": "^6.10.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2",
    "sharp": "^0.33.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.25",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.27",
    "@types/nodemailer": "^7.0.4",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prisma": "^5.22.0",
    "rimraf": "^5.0.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
