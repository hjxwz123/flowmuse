# Database
DATABASE_URL="postgresql://user:password@localhost:5432/aigallery"

# Redis (BullMQ queues)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=1

# Storage
STORAGE_DRIVER="cos" # cos | local

# Tencent Cloud COS (required when STORAGE_DRIVER=cos)
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_REGION="ap-beijing"
COS_BUCKET="your-bucket"
# Optional: custom domain/CDN base url, e.g. https://cdn.example.com
COS_PUBLIC_BASE_URL=""
# Optional: set "public-read" if your bucket supports it
COS_ACL=""

# Server
PORT=3000
FRONTEND_PORT=3001
# 前端服务转发后端 API（源码部署建议保持与 PORT 一致）
BACKEND_URL="http://127.0.0.1:3000"

# Public URL (used for emails and file links)
# 开发环境
# APP_PUBLIC_URL="http://localhost:3000"
# FRONTEND_URL="http://localhost:5173"

# 生产环境（修改为你的实际域名或IP）
APP_PUBLIC_URL="http://your-server-ip:3000"
FRONTEND_URL="http://your-server-ip:80"

# Optional: verify Midjourney callback requests (sent as `x-webhook-secret`)
MJ_WEBHOOK_SECRET=""

# JWT
JWT_ACCESS_SECRET="change-me-to-random-string"
JWT_REFRESH_SECRET="change-me-to-another-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# Security (for encrypting api keys, reset tokens, etc.)
APP_ENCRYPTION_KEY="change-me-32-bytes-minimum-length"

# SMTP (optional; if not set, emails will be logged instead)
SMTP_HOST="smtp.example.com"
SMTP_PORT=465
SMTP_USER="your_email@example.com"
SMTP_PASS="your_auth_code_here"
SMTP_FROM="AI Gallery <your_email@example.com>"

# OpenAI-compatible external deep research API key (Bearer token)
OPENAI_DEEP_RESEARCH_API_KEY="replace-with-strong-random-key"
