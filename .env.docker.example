# Docker images. Replace these with your published image names.
BACKEND_IMAGE=ghcr.io/your-username/flowmuse-backend:latest
FRONTEND_IMAGE=ghcr.io/your-username/flowmuse-frontend:latest

# Public ports
BACKEND_PORT=3000
FRONTEND_PORT=3001
MYSQL_PORT=3306
REDIS_PORT=6379

# MySQL
MYSQL_ROOT_PASSWORD=change_root_password
MYSQL_DATABASE=flowmuse
MYSQL_USER=flowmuse
MYSQL_PASSWORD=change_db_password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Backend runtime
PORT=3000
DATABASE_URL=mysql://flowmuse:change_db_password@mysql:3306/flowmuse?charset=utf8mb4
APP_PUBLIC_URL=http://your-domain-or-ip:3000
FRONTEND_URL=http://your-domain-or-ip:3001

# Frontend runtime proxy target inside Docker network
BACKEND_URL=http://backend:3000
NEXT_PUBLIC_API_BASE_URL=/api

# Security. Must be changed in production.
JWT_ACCESS_SECRET=change-me-to-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
APP_ENCRYPTION_KEY=change-me-32-bytes-minimum-length

# Storage: local or cos
STORAGE_DRIVER=local
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-beijing
COS_BUCKET=
COS_PUBLIC_BASE_URL=
COS_ACL=

# Integrations
MJ_WEBHOOK_SECRET=
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=FlowMuse <noreply@example.com>
OPENAI_DEEP_RESEARCH_API_KEY=
